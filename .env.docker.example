# Copy to `.env.docker` in this folder, then run:
#   docker compose --env-file .env.docker up --build
# (Compose only auto-loads `.env`, not `.env.docker`.)

WEB_PORT=3000

# Server-side proxy target (Next `src/app/api/[...path]/route.ts`). From inside the web container:
# - API on your machine (Docker Desktop): host.docker.internal
# - API in Compose on the same network: http://city-transit-api:9081/city-transit-api/api
API_BASE=http://host.docker.internal:9081/city-transit-api

# Optional client fallback if you ever call the API with an absolute URL from the browser
NEXT_PUBLIC_API_BASE=http://localhost:9081/city-transit-api

# Optional map features
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyCFiyOt5VkJBh8iR5vUCRs9kJQ427FF0-w
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=AIzaSyCFiyOt5VkJBh8iR5vUCRs9kJQ427FF0-w

# Backend base URL used by the server-side proxy at `src/app/api/[...path]/route.ts`.
# Prefer `API_BASE`. `NEXT_PUBLIC_API_BASE` is used as a local-dev fallback.
# city-transit-api default: port 9081, context path /city-transit-api, REST prefix /api
API_BASE=http://localhost:9081/city-transit-api
NEXT_PUBLIC_API_BASE=http://localhost:9081/city-transit-api

# Optional (used in map components)
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=AIzaSyCFiyOt5VkJBh8iR5vUCRs9kJQ427FF0-w
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyCFiyOt5VkJBh8iR5vUCRs9kJQ427FF0-w
